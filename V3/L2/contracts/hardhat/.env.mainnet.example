# ─────────────────────────────────────────────────────────────────────────────
# ZION 3.0.4 — Multi-Chain Mainnet Deploy Environment
# Copy to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Deployer wallet — 0xdde17506BC2D2dCE1d594bD1D85B0BAbb389D186
# Needs ETH on each target chain for gas (Base + Arbitrum)
DEPLOYER_PRIVATE_KEY=

# ── Base Mainnet ──────────────────────────────────────────────────────────────
# Note: hardhat.config.ts reads BASE_RPC (not BASE_MAINNET_RPC)
BASE_RPC=https://mainnet.base.org

# Basescan API key for contract verification
# Get from: https://basescan.org/myapikey
BASESCAN_API_KEY=

# ── Arbitrum One Mainnet ──────────────────────────────────────────────────────
# Bridge ETH from Ethereum to Arbitrum: https://bridge.arbitrum.io
ARB_RPC=https://arb1.arbitrum.io/rpc

# Arbiscan API key for contract verification
# Get from: https://arbiscan.io/myapikey
ARBISCAN_API_KEY=

# ── BNB Smart Chain Mainnet ───────────────────────────────────────────────────
# Get BNB for gas: https://www.binance.com (or bridge via https://www.bnbchain.org/en/bridge)
BSC_RPC=https://bsc-dataseed.binance.org

# BscScan API key for contract verification
# Get from: https://bscscan.com/myapikey
BSCSCAN_API_KEY=

# ── Polygon PoS Mainnet ───────────────────────────────────────────────────────
# Get POL for gas: https://wallet.polygon.technology/bridge
POLYGON_RPC=https://polygon-rpc.com

# PolygonScan API key for contract verification
# Get from: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# ── Optimism Mainnet ──────────────────────────────────────────────────────────
# Bridge ETH to Optimism: https://app.optimism.io/bridge
OP_RPC=https://mainnet.optimism.io

# Optimistic Etherscan API key
# Get from: https://optimistic.etherscan.io/myapikey
OPSCAN_API_KEY=

# ── Avalanche C-Chain Mainnet ─────────────────────────────────────────────────
# Get AVAX for gas: https://bridge.avalabs.org
AVAX_RPC=https://api.avax.network/ext/bc/C/rpc

# Snowtrace API key for contract verification
# Get from: https://snowtrace.io/myapikey
SNOWTRACE_API_KEY=

# ── Validator set (5/5 multisig — same across all chains) ─────────────────────
# These are the default validators from Base deploy. Override only if rotating.
# VALIDATOR_1=0xdde17506BC2D2dCE1d594bD1D85B0BAbb389D186
# VALIDATOR_2=0x24d986841E56e5571489B25951eE8C1Ae761FA82
# VALIDATOR_3=0x665c55eDCF25c2c5A1dfF1B20eE950cBDC58d3d0
# VALIDATOR_4=0x8E644b3E9FaBf52eE321DC5B3D5AA06d6e3E66C6
# VALIDATOR_5=0x7e0D2eD71d78B9CFB5034A83333e82e304bc4CB2
# BRIDGE_THRESHOLD=5

# ─── Already deployed (do not change) ────────────────────────────────────────

# wZION ERC-20 token (Base Mainnet, verified)
WZION_ADDRESS=0x0c493763d107ab0ABb0aee1Ca3999292d8202bb6

# ZIONBridge v3 (Base Mainnet, 5/5 validators)
BRIDGE_ADDRESS=0x72c8f0Dc60E27aB7A83fe3B416fab4F0600a6467

# ZIONAtomicSwap (Base Mainnet)
ATOMIC_SWAP_ADDRESS=0x3DE9Ad42716854083ab837706E3961d10B0e63Eb

# ─── New 3.0.4 deploy configuration ──────────────────────────────────────────

# Guardian address (emergency pause/unpause) — use deployer initially, rotate to multisig later
GUARDIAN_ADDRESS=0xdde17506BC2D2dCE1d594bD1D85B0BAbb389D186

# Optional: second treasury multisig signer (leave empty for single-sig initially)
TREASURY_SIGNER2=

# ZIONStaking APR in basis points (1200 = 12% APR)
STAKING_APR_BPS=1200

# ZIONFarm initial reward rate in wZION wei per second
# 1000000000000000000 = 1 wZION/s = 86,400 wZION/day (conservative start)
# 3000000000000000000 = 3 wZION/s (used on Sepolia testnet)
FARM_REWARD_PER_SEC=1000000000000000000

# ZIONFarm halving interval in seconds (7776000 = 90 days)
FARM_HALVING_INTERVAL=7776000

# ─── Post-deploy: fill after running deploy scripts ──────────────────────────
# These will be populated in deployed-defi.json and deployed-farm-base.json

# DEPLOYED_STAKING=0x
# DEPLOYED_FARM=0x
# DEPLOYED_GOVERNANCE=0x
# DEPLOYED_TREASURY=0x
